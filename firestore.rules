rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string &&
             data.displayName is string &&
             data.displayName.size() < 100;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['userId', 'date', 'sins', 'score']) &&
             data.userId == request.auth.uid &&
             data.date is string &&
             data.sins is list &&
             data.score is number;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /logs/{logId} {
      // Permite ler se o documento for seu OU se o ID começar com seu UID (para verificar existência)
      allow read: if isAuthenticated() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (resource == null && logId.startsWith(request.auth.uid))
      );
      
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
